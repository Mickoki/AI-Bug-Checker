# Kazakhstan Security Agent System - Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# LLM Configuration (8GB RAM limit - Ollama)
# ============================================
# IMPORTANT: All requests must stay within Kazakhstan (KZ)
# PROHIBITED: openai, anthropic, grok, deepseek

# Default: Ollama on localhost
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=qwen2.5-3b-instruct

# Alternative: OpenAI-compatible endpoint (llama.cpp, vLLM)
# LLM_ENDPOINT=http://localhost:8080/v1
# LLM_MODEL=qwen2.5-3b-instruct

LLM_API_KEY=

# ============================================
# Knowledge Base Database
# ============================================
KB_DB_HOST=localhost
KB_DB_PORT=5432
KB_DATABASE=knowledge_base
KB_USER=postgres
KB_PASSWORD=your_password_here

# Embedding model for vector search
EMBEDDING_ENDPOINT=http://localhost:8081/embed
VECTOR_DIMENSION=1536

# ============================================
# Agent State Persistence
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here

# ============================================
# Code Scanning
# ============================================
SEMGREP_RULES_PATH=./rules/semgrep
CODEQL_DATABASES_PATH=./codeql_dbs
TARGET_LANGUAGES=python,javascript,java,go,rust
SEVERITY_THRESHOLD=medium

# ============================================
# Security & Compliance
# ============================================
DATA_RESIDENCY=KZ
ALLOWED_REGIONS=KZ
LOG_LEVEL=INFO
AUDIT_LOG_PATH=./logs/audit.log

# ============================================
# Monitoring
# ============================================
METRICS_PORT=9090
METRICS_ENABLED=true